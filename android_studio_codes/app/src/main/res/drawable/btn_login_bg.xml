<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Glow extérieur violet -->
    <item
        android:left="0dp"
        android:top="4dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#4C1D95"/>
            <corners android:radius="50dp"/>
        </shape>
    </item>

    <!-- Bouton principal violet brillant -->
    <item
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#7C3AED"
                android:centerColor="#6D28D9"
                android:endColor="#5B21B6"
                android:angle="270"/>
            <corners android:radius="50dp"/>
            <stroke
                android:width="1dp"
                android:color="#A78BFA"/>
        </shape>
    </item>

</layer-list>