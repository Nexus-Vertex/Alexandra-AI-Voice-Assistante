<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Bordure violette lumineuse extérieure (glow effect) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#3B1F7A"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>

    <!-- Bordure violette intérieure -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A0D35"/>
            <corners android:radius="27dp"/>
            <stroke
                android:width="1dp"
                android:color="#5B21B6"/>
        </shape>
    </item>

    <!-- Fond glassmorphism sombre -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#0E0B2A"/>
            <corners android:radius="26dp"/>
        </shape>
    </item>

</layer-list>