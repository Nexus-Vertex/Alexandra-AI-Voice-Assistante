<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardRappel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Barre colorée gauche -->
            <View
                android:id="@+id/viewStripe"
                android:layout_width="3dp"
                android:layout_height="50dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/stripe_purple"/>

            <!-- Icône -->
            <TextView
                android:id="@+id/tvRappelIcon"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:gravity="center"
                android:textSize="22sp"
                android:background="@drawable/bg_rappel_icon_purple"
                android:layout_marginEnd="14dp"
                android:text="🔔"/>

            <!-- Contenu -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvRappelMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_main"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginBottom="5dp"
                    android:text="Rappel message"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Dot indicateur -->
                    <View
                        android:layout_width="5dp"
                        android:layout_height="5dp"
                        android:background="@drawable/dot_purple"
                        android:layout_marginEnd="5dp"/>

                    <TextView
                        android:id="@+id/tvRappelDateTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"
                        android:text="Demain · 14:00"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvRappelBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BIENTÔT"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:letterSpacing="0.05"
                        android:background="@drawable/badge_soon"/>

                </LinearLayout>
            </LinearLayout>

            <!-- Bouton supprimer -->
            <ImageButton
                android:id="@+id/btnDeleteRappel"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_btn_delete"
                android:src="@drawable/ic_delete"
                android:tint="@color/text_muted"
                android:contentDescription="Supprimer"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Bordure violette autour de la card -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/border_card_rappel"/>

</FrameLayout>