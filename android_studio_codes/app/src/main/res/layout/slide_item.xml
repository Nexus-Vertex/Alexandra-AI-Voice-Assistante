<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient">

    <!-- TITRE EN HAUT -->
    <TextView
        android:id="@+id/txtTitleTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="72dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="24sp"
        android:lineSpacingExtra="4dp"
        android:fontFamily="sans-serif-medium"/>

    <!-- DESCRIPTION EN HAUT -->
    <TextView
        android:id="@+id/txtDescTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:gravity="center"
        android:textColor="#94A3B8"
        android:textSize="15sp"
        android:lineSpacingExtra="4dp"/>

    <!-- IMAGE -->
    <ImageView
        android:id="@+id/imgSlide"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:scaleType="fitCenter"/>

    <!-- TITRE EN BAS (slides 2 et 3 seulement) -->
    <TextView
        android:id="@+id/txtTitleBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="22sp"
        android:lineSpacingExtra="4dp"
        android:fontFamily="sans-serif-medium"/>

    <!-- DESCRIPTION EN BAS (slides 2 et 3 seulement) -->
    <TextView
        android:id="@+id/txtDescBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:gravity="center"
        android:textColor="#94A3B8"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"/>

    <!-- ===== LOGO ZONE SLIDE 1 UNIQUEMENT ===== -->
    <LinearLayout
        android:id="@+id/logoArea"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="18dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/logoIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_alexandra_logo"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/logoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alexandra"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:fontFamily="sans-serif-condensed-medium"/>

        </LinearLayout>

        <TextView
            android:id="@+id/logoSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ton assistante vocale intelligente."
            android:textColor="#94A3B8"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:gravity="center"/>

    </LinearLayout>

</LinearLayout>