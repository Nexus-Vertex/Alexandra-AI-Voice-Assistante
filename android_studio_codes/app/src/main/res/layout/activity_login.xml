<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login">

    <!-- CONTENEUR CENTRAL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="28dp"
        android:paddingEnd="28dp">

        <!-- MICRO LUMINEUX AU-DESSUS DE LA CARD -->
        <RelativeLayout
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginBottom="-2dp">

            <View
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_centerInParent="true"
                android:background="@drawable/mic_glow_bg"/>

            <ImageView
                android:id="@+id/imgMic"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_centerInParent="true"
                android:src="@drawable/ic_mic_neon"/>

        </RelativeLayout>

        <!-- CARD GLASSMORPHISM -->
        <LinearLayout
            android:id="@+id/loginCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/login_card_bg"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="36dp"
            android:paddingBottom="36dp">

            <!-- Titre -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bon retour"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="sans-serif-condensed-medium"
                android:letterSpacing="0.02"
                android:layout_marginBottom="10dp"/>

            <!-- Sous-titre -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Connecte-toi pour retrouver Alexandra."
                android:textColor="#94A3B8"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginBottom="32dp"/>

            <!-- CHAMP EMAIL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:background="@drawable/input_field_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_email_field"
                    android:layout_marginEnd="14dp"/>

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Adresse e-mail"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#4B5563"
                    android:textSize="16sp"
                    android:inputType="textEmailAddress"
                    android:background="@null"
                    android:importantForAutofill="no"/>

            </LinearLayout>

            <!-- CHAMP MOT DE PASSE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:background="@drawable/input_field_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginBottom="28dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_lock_field"
                    android:layout_marginEnd="14dp"/>

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Mot de passe"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#4B5563"
                    android:textSize="16sp"
                    android:inputType="textPassword"
                    android:background="@null"
                    android:importantForAutofill="no"/>

                <ImageView
                    android:id="@+id/btnTogglePassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_eye_field"
                    android:alpha="0.7"/>

            </LinearLayout>

            <!-- BOUTON SE CONNECTER -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Se connecter"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.03"
                android:background="@drawable/btn_login_bg"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:layout_marginBottom="20dp"/>

            <!-- Mot de passe oublié -->
            <TextView
                android:id="@+id/btnForgotPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mot de passe oublié ?"
                android:textColor="#94A3B8"
                android:textSize="14sp"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Lien S'inscrire sous la card -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pas encore de compte ? "
                android:textColor="#64748B"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/btnGoRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S'inscrire"
                android:textColor="#A78BFA"
                android:textSize="14sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>